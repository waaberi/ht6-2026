# Use a flat (hoisted) node_modules layout instead of pnpm's default deep
# .pnpm/<name>@<version>_<hash>/node_modules/<name>/ symlink tree.
#
# Expo/React Native compile native C++ (expo-modules-core, reanimated, skia, ...)
# with CMake + ninja, which on Windows enforce a ~250-char object-file path limit
# (CMAKE_OBJECT_PATH_MAX) that the OS LongPathsEnabled flag does NOT lift. pnpm's
# deep default layout blows past it (`ninja: manifest 'build.ninja' still dirty`).
# Hoisting keeps packages at short paths like node_modules/expo-modules-core/, so
# the generated .cxx build paths stay under the limit. Harmless on macOS/Linux.
node-linker=hoisted
