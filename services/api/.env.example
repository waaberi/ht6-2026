GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Optional comma-separated text models tried in order for quota or model-availability errors.
GEMINI_FALLBACK_MODELS=
GEMINI_THINKING_LEVEL=low
NANO_BANANA_MODEL=gemini-3.1-flash-image
EXPOSURE_MAX_UPLOAD_BYTES=26214400
EXPOSURE_SEMANTIC_TIMEOUT_SECONDS=25
EXPOSURE_COACH_TIMEOUT_SECONDS=25
EXPOSURE_IMAGE_TIMEOUT_SECONDS=90

# ElevenLabs stays server-side. Flash gives the Coach low-latency narration.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_TIMEOUT_SECONDS=30

# Keep disabled for local development and the unauthenticated network smoke.
# Set true in production to require a valid Auth0 Bearer token on every /v1 endpoint.
EXPOSURE_REQUIRE_AUTH=false
EXPOSURE_AUTH_TIMEOUT_SECONDS=5
AUTH0_DOMAIN=dev-40ogr4b5dnzkfkp3.us.auth0.com
AUTH0_AUDIENCE=https://api.exposure.app

# MongoDB Atlas is the structured-data store. Keep these values server-side.
MONGODB_USERNAME=atlas-database-user
MONGODB_PASSWORD=atlas-database-password
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=exposure
