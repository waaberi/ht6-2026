{
  "expo": {
    "name": "Exposure",
    "slug": "exposure",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "exposure",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ht62026.exposure"
    },
    "android": {
      "package": "com.ht62026.exposure",
      "adaptiveIcon": {
        "backgroundColor": "#221A1B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Exposure to use the camera for photographs",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Exposure to import photographs"
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Allow Exposure to show a live camera level"
        }
      ],
      "./plugins/withAndroidNinja",
      "./plugins/withAndroidCleartextTraffic",
      "expo-video"
    ]
  }
}
