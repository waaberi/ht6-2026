{
  "name": "exposure-workspace",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.9.0"
  },
  "scripts": {
    "bootstrap": "node scripts/setup.mjs",
    "android": "node apps/mobile/scripts/android.mjs install",
    "dev": "node scripts/dev.mjs",
    "phone": "node scripts/phone-tailscale.mjs",
    "phone:tailscale": "node scripts/phone-tailscale.mjs",
    "api": "uv --directory services/api run uvicorn exposure_api.main:app --reload --env-file .env.local",
    "network:smoke": "node scripts/smoke-network.mjs",
    "production:smoke": "node scripts/smoke-production.mjs",
    "db:test": "uv --directory services/api run --env-file .env.local python scripts/smoke_mongodb.py",
    "db:migrate": "uv --directory services/api run --env-file .env.local python scripts/migrate_supabase_to_mongodb.py",
    "test:mobile": "pnpm --filter exposure run typecheck && pnpm --filter exposure run test && pnpm --filter exposure run doctor",
    "test:api": "uv --directory services/api run pytest",
    "test:db": "pnpm db:test",
    "test": "pnpm test:mobile && pnpm test:api && pnpm test:db"
  },
  "devDependencies": {
    "supabase": "2.109.1"
  }
}
